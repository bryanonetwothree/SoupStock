# ============================================================
# SoupStock Frontend – Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# Variables must start with VITE_ to be exposed to the browser.
# Never commit your actual .env file to Git!
# ============================================================

# URL of your running backend API
# During local development: http://localhost:8000
# In production: your Render URL e.g. https://soupstock-api.onrender.com
VITE_API_BASE_URL=http://localhost:8000
