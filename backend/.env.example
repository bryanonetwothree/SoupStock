# ============================================================
# SoupStock Backend – Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# Never commit your actual .env file to Git!
# ============================================================

# Your Supabase project URL
# Found in: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/service key
# Found in: Supabase Dashboard → Project Settings → API → anon public key
# For a self-hosted family app, the anon key is fine.
# If you want extra security, use the service_role key (keep it secret!).
SUPABASE_KEY=your-supabase-anon-key-here

# The URL of your deployed frontend (used for CORS)
# During local development: http://localhost:5173
# In production: your Vercel URL e.g. https://soupstock.vercel.app
FRONTEND_URL=http://localhost:5173
